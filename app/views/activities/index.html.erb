<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Triangle Tots</h1>
        <p class="text-lg text-gray-600">An activities app for everyone! (That lives in Chapel Hill and has a 3-year-old)</p>
      </div>
      <div class="flex flex-col items-end gap-2 mt-2">
        <% if authenticated? %>
          <div class="flex items-center gap-3 text-sm">
            <span class="text-gray-600"><%= Current.user.email_address %></span>
            <%= button_to "Log out", session_path, method: :delete, class: "text-blue-600 hover:text-blue-800 underline" %>
          </div>
        <% else %>
          <div class="flex items-center gap-3 text-sm">
            <%= link_to "Log in", new_session_path, class: "text-blue-600 hover:text-blue-800 underline" %>
            <%= link_to "Sign up", new_registration_path, class: "text-blue-600 hover:text-blue-800 underline" %>
          </div>
        <% end %>
        <% if @home_location %>
          <a href="#" onclick="LocationManager.clearLocation(); LocationManager.requestGeolocation(); return false;" class="text-sm text-blue-600 hover:text-blue-800 underline whitespace-nowrap">
            Change Location
          </a>
        <% end %>
      </div>
    </div>

    <%# Weather indicator %>
    <% if @current_weather %>
      <div class="mt-5 flex items-center gap-2 px-4 py-2 bg-blue-50 border border-blue-100 rounded-full text-sm shadow-sm w-fit">
        <span class="text-base"><%= weather_icon(@current_weather[:condition]) %></span>
        <% if @current_weather[:temp_f] %>
          <span class="font-semibold text-gray-900"><%= @current_weather[:temp_f] %>&deg;</span>
        <% end %>
        <% if @weather_strategy == :hide_outdoor %>
          <span class="text-blue-700 font-medium">Rain expected &mdash; indoor only</span>
        <% elsif @weather_strategy == :deprioritize_outdoor %>
          <span class="text-blue-700 font-medium">Rain in forecast</span>
        <% elsif @current_weather[:condition].present? %>
          <span class="text-gray-600"><%= @current_weather[:condition] %></span>
        <% end %>
        <% if @current_weather[:high_f] && @current_weather[:low_f] %>
          <span class="text-gray-300">&middot;</span>
          <span class="text-gray-500">H:<%= @current_weather[:high_f] %>&deg; L:<%= @current_weather[:low_f] %>&deg;</span>
        <% end %>
        <% if @current_weather[:precip_chance] && @current_weather[:precip_chance] > 0 %>
          <span class="text-gray-300">&middot;</span>
          <span class="text-blue-600"><%= @current_weather[:precip_chance] %>% rain</span>
        <% end %>
      </div>
    <% end %>

    <%# Tabs %>
    <div class="mt-6 border-b border-gray-200">
      <nav class="-mb-px flex space-x-8">
        <%= link_to activities_path(view: "now", home_lat: @home_location[:latitude], home_lng: @home_location[:longitude], type_filter: @type_filter),
                    class: "#{@view_mode == 'now' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" do %>
          Now
        <% end %>
        <%= link_to activities_path(view: "weekend", home_lat: @home_location[:latitude], home_lng: @home_location[:longitude], type_filter: @type_filter),
                    class: "#{@view_mode == 'weekend' ? 'border-blue-500 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'} whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm" do %>
          Weekend Events
        <% end %>
      </nav>
    </div>

    <%# Activity type filter dropdown + count %>
    <% available_types = Activity.distinct.pluck(:activity_type).compact.sort %>
    <div class="mt-4 flex items-center gap-4">
      <select onchange="window.location = this.value"
              class="text-sm border border-gray-300 rounded-md px-3 py-1.5 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        <option value="<%= activities_path(view: @view_mode, home_lat: @home_location[:latitude], home_lng: @home_location[:longitude]) %>"
                <%= 'selected' if @type_filter.nil? %>>All types</option>
        <% available_types.each do |type| %>
          <option value="<%= activities_path(view: @view_mode, home_lat: @home_location[:latitude], home_lng: @home_location[:longitude], type_filter: type) %>"
                  <%= 'selected' if @type_filter == type %>><%= activity_type_label(type) %></option>
        <% end %>
      </select>
      <p class="text-sm text-gray-500">
        <% if @view_mode == "weekend" %>
          <%= pluralize(@activities.count, "event") %> this weekend
        <% else %>
          <%= @activities.count %> available now
        <% end %>
      </p>
    </div>
  </div>

  <% if @activities.empty? %>
    <%# Empty state %>
    <div class="text-center py-12">
      <% if @view_mode == "weekend" %>
        <p class="text-gray-500 text-lg">No events scheduled for this weekend.</p>
        <p class="text-gray-400 text-sm mt-2">Check back later or explore other activities!</p>
      <% elsif @view_mode == "now" %>
        <p class="text-gray-500 text-lg">No activities available right now</p>
        <p class="text-gray-400 text-sm mt-2">Check back later or switch to "All Activities" to see the full list</p>
      <% else %>
        <p class="text-gray-500 text-lg">No activities found</p>
      <% end %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @activities.each do |activity| %>
        <%= link_to activity_path(activity), class: "block bg-white rounded-lg shadow-md hover:shadow-lg transition-shadow duration-200 overflow-hidden" do %>
          <div class="p-6">
            <%# Top row: Icon left, name + badge stacked right %>
            <div class="flex items-start gap-3 mb-3">
              <div class="flex-shrink-0">
                <%= activity_icon(activity.activity_type, size: 64) %>
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="text-xl font-semibold text-gray-900"><%= activity.name %></h2>
                <div class="mt-1 flex flex-wrap gap-2">
                  <% if @view_mode == "now" && activity.status %>
                    <%= format_status_badge(activity) %>
                  <% end %>
                  <% if activity.cost_level == 0 %>
                    <span class="px-2 py-1 text-xs font-medium rounded" style="background-color: #F5C878; color: #7C5209; opacity: 0.75;">FREE</span>
                  <% else %>
                    <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs font-medium rounded"><%= "$" * activity.cost_level %></span>
                  <% end %>
                </div>
              </div>
            </div>

            <p class="text-gray-600 text-sm line-clamp-2 mb-4"><%= activity.description %></p>

            <%# Show event date/time for weekend view %>
            <% if @view_mode == "weekend" && activity.start_date %>
              <p class="text-sm text-blue-600 font-medium mb-3">
                <%= activity.start_date.strftime("%A, %B %d at %I:%M %p") %>
              </p>
            <% end %>

            <%# Address row with distance and rating buttons %>
            <%
              interaction = @interactions[activity.id.to_s]
              has_thumbs_up = interaction && interaction['rating'] == 1
              has_thumbs_down = interaction && interaction['rating'] == -1
            %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2 text-sm text-gray-500">
                <svg class="inline-block w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span><%= activity.address&.split(',')&.first || 'Chapel Hill/Durham' %></span>
                <% if @home_location %>
                  <span class="text-gray-400">•</span>
                  <span><%= format_distance(activity.distance) %></span>
                <% end %>
              </div>

              <%# Rating buttons on far right %>
              <div class="flex gap-2 flex-shrink-0 ml-4">
                <button
                  onclick="event.stopPropagation(); event.preventDefault(); ActivityInteractions.rate(<%= activity.id %>, 1); return false;"
                  class="px-2 py-1 rounded border <%= has_thumbs_up ? 'bg-green-100 border-green-500' : 'border-gray-300 hover:bg-green-50 hover:border-green-400' %> transition-colors"
                  data-activity-id="<%= activity.id %>"
                  data-interaction-type="thumbs-up"
                  title="I like this activity"
                >
                  <span class="text-lg">👍</span>
                </button>

                <button
                  onclick="event.stopPropagation(); event.preventDefault(); ActivityInteractions.rate(<%= activity.id %>, -1); return false;"
                  class="px-2 py-1 rounded border <%= has_thumbs_down ? 'bg-red-100 border-red-500' : 'border-gray-300 hover:bg-red-50 hover:border-red-400' %> transition-colors"
                  data-activity-id="<%= activity.id %>"
                  data-interaction-type="thumbs-down"
                  title="Not interested in this activity"
                >
                  <span class="text-lg">👎</span>
                </button>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
